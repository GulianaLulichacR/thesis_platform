# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
APP_NAME="Thesis Review AI Platform"
ENVIRONMENT=development
DEBUG=true

LOG_LEVEL=INFO
LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─────────────────────────────────────────────────────────────
# OLLAMA (LOCAL FALLBACK)
# ─────────────────────────────────────────────────────────────
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────────────────────
# GEMINI (FREE TIER)
# https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_ENABLED=true
GEMINI_API_KEY=AQ.Ab8RN6I8kkdhBgqGFIuj7ckFldep4-htoWI6Q8OAMLGQmXroEw
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# ─────────────────────────────────────────────────────────────
# LLM CONFIG
# ─────────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-1.5-flash

# IMPORTANT: must be valid JSON
# The backend will try Gemini first. If you hit error 429, it falls back to Ollama.
LLM_PROVIDER_PRIORITY=["gemini", "ollama"]

# Request settings
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=30.0
LLM_REQUEST_TIMEOUT=120.0

# Cache (helps save free-tier quota)
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=300
LLM_CACHE_MAX_SIZE=256

# ─────────────────────────────────────────────────────────────
# STORAGE
# ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

UPLOAD_DIR=uploads
DATA_DIR=data
VECTOR_DB_DIR=vector_db